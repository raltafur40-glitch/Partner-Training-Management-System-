    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ======================================\n// WF-03 - Reminder Eligibility Engine\n// ======================================\n\n// ---------- Configuration ----------\nconst CONFIG = {\n    reminderIntervalDays: 3,\n    maxReminderCount: 5\n};\n\n// ---------- Read Notion Properties ----------\n\nconst props = $json.properties;\n// Partner Information\nconst partnerName =\n    props[\"Partner Name\"]?.title?.[0]?.plain_text ?? \"\";\n\nconst partnerEmail =\n    props[\"Email\"]?.email ?? \"\";\n\nconst company =\n    props[\"Company\"]?.rich_text?.[0]?.plain_text ?? \"\";\n\nconst trainingProgram =\n    props[\"Training Program\"]?.select?.name ?? \"\";\n\n// Reminder Count\nconst reminderCount =\n    props[\"Reminder Count\"]?.number ?? 0;\n\n// Last Reminder Sent\nconst lastReminder =\n    props[\"Last Reminder Sent\"]?.date?.start ?? null;\n\n// Training Status\nconst trainingStatus =\n    props[\"Training Status\"]?.status?.name ?? \"\";\n\n// Needs Reminder Flag\nconst needsReminder =\n    props[\"Needs Reminder\"]?.checkbox ?? false;\n\n// Manager Escalation Flag\nconst needsManagerEscalation =\n    props[\"Needs Manager Escalation\"]?.checkbox ?? false;\n\n// Due Soon Flag\nconst dueSoon =\n    props[\"Due Soon\"]?.checkbox ?? false;\n\nconst managerMap = {\n\n    \"Commerce Platform\": \"sarah.ahmed@yourcompany.com\",\n\n    \"Product Basics\": \"sarah.ahmed@yourcompany.com\",\n\n    \"API Integration\": \"sarah.ahmed@yourcompany.com\",\n\n    \"Experimentation\": \"sarah.ahmed@yourcompany.com\",\n\n    \"CMS Training\": \"sarah.ahmed@yourcompany.com\"\n\n};\n\nconst managerEmail =\n    managerMap[trainingProgram] ?? \"\";\n// ======================================\n// Eligibility\n// ======================================\n\nlet eligible = false;\nlet reminderType = \"None\";\n\nif (needsReminder) {\n\n    if (reminderCount < CONFIG.maxReminderCount) {\n\n        if (!lastReminder) {\n\n            eligible = true;\n\n        } else {\n\n            const today = new Date();\n            today.setHours(0,0,0,0);\n\n            const last = new Date(lastReminder);\n            last.setHours(0,0,0,0);\n\n            const daysSinceLastReminder =\n                Math.floor(\n                    (today-last)/(1000*60*60*24)\n                );\n\n            if(daysSinceLastReminder >= CONFIG.reminderIntervalDays){\n\n                eligible = true;\n\n            }\n\n        }\n\n    }\n\n}\n\n// ======================================\n// Reminder Type\n// ======================================\n\nif(eligible){\n\n    if(trainingStatus===\"Overdue\"){\n\n        reminderType=\"Overdue\";\n\n    }\n\n    else if(dueSoon){\n\n        reminderType=\"Due Soon\";\n\n    }\n\n    else{\n\n        reminderType=\"Regular\";\n\n    }\n\n}\n\n// ======================================\n\nreturn {\n    json: {\n        ...$json,\n\n        reminderCount,\n        lastReminder,\n\n        eligible,\n        reminderType,\n\n        trainingStatus,\n        dueSoon,\n        needsReminder,\n        needsManagerEscalation,\n      partnerName,\n      partnerEmail,\n      company,\n      trainingProgram,\n      managerEmail\n\n    }\n\n};"
      },
      "type": "n8n-nodes-base.code",
